#!/bin/sh
# photo - main CLI entry point for photo-os workflow
# Usage: photo <command> [arguments]

set -e

# Resolve the real location of this script, following symlinks.
# macOS readlink does not support -f, so we walk the chain manually.
_real_dir() {
    target="$1"
    while [ -L "$target" ]; do
        link="$(readlink "$target")"
        case "$link" in
            /*) target="$link" ;;                                   # absolute symlink
            *)  target="$(dirname "$target")/$link" ;;             # relative symlink
        esac
    done
    cd "$(dirname "$target")" && pwd
}

SCRIPT_DIR="$(_real_dir "$0")"
LIB_DIR="$SCRIPT_DIR/lib"
CMD_DIR="$SCRIPT_DIR/commands"

# Load shared library
. "$LIB_DIR/common.sh"

# Ensure config exists
config_init

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    new)         . "$CMD_DIR/new.sh"         && cmd_new "$@" ;;
    import)      . "$CMD_DIR/import.sh"      && cmd_import "$@" ;;
    export)      . "$CMD_DIR/export.sh"      && cmd_export "$@" ;;
    backup)      . "$CMD_DIR/backup.sh"      && cmd_backup "$@" ;;
    current)     . "$CMD_DIR/current.sh"     && cmd_current "$@" ;;
    open)        . "$CMD_DIR/open.sh"        && cmd_open "$@" ;;
    export-path) . "$CMD_DIR/export-path.sh" && cmd_export_path "$@" ;;
    status)      . "$CMD_DIR/status.sh"      && cmd_status "$@" ;;
    help|-h|--help)
        cat <<EOF
photo - photo-os workflow CLI

Usage: photo <command> [arguments]

Session commands:
  new          <"YYYY-MM-DD Project">        Create a new session folder structure
  import       [source] [--session NAME]     Import RAW files; auto-detects SD card
  current                                    Show current session paths
  open         <raw|export|portfolio>        Open a session folder in Finder
  export-path                                Print web export path (for darktable)

Export commands:
  export       [web|print] [--dry-run]       Batch export via darktable-cli
  export-path                                Print web export path (paste into darktable)

Library commands:
  backup       [--dest primary|secondary]    Sync library to backup destinations
  status                                     Show library summary

Other:
  help                                       Show this message

Typical workflow:
  photo import                # auto-detect SD card, import, set current session
  photo current               # show paths for current session
  photo export web            # batch export all RAW files via darktable-cli
  photo open export           # review exported JPEGs in Finder
  photo backup                # sync to backup drive

Config: ~/.photo-os/config
Docs:   https://github.com/henry-wu-1130/photo-os
EOF
        ;;
    *)
        log_error "Unknown command: $COMMAND"
        log_info  "Run 'photo help' for usage."
        exit 1
        ;;
esac
